######################################################
# EVERYTHING HERE WILL BE REMOVED ON SERVICE RESTART #
######################################################

# The `systab` crontab is here exclusively for /etc/cron.* compatibility

# If you need to run a cron job as root, use root's crontab
# As root: fcrontab -e


!bootrun(true),nice(15),serial(true)
%hourly  0       run-parts --report /etc/cron.hourly
%daily   * 3-6   run-parts --report /etc/cron.daily
%weekly  * 3-6   run-parts --report /etc/cron.weekly
%monthly * 3-6 * run-parts --report /etc/cron.monthly
